generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  SUPERVISOR
  COMPRAS
  COMMERCIAL
  CONSULTA
}

enum ClientType {
  PUBLIC
  PRIVATE
}

enum ContractStatus {
  ACTIVE
  PROLONGATION
  SUSPENDED
  FINISHED
  CANCELLED
}

enum ExpenseCategory {
  UNIFORMS
  AUDIT_FINDINGS
  DEFERRED
  ADMIN
  TRANSPORT
  FUEL
  PHONES
  OTHER
}

enum ExpenseType {
  APERTURA
  UNIFORMS
  AUDIT
  ADMIN
  TRANSPORT
  FUEL
  PHONES
  PLANILLA
  OTHER
}

/// Partida presupuestaria del gasto (distribución del contrato)
enum ExpenseBudgetLine {
  LABOR       // Mano de obra
  SUPPLIES    // Insumos
  ADMIN       // Gasto administrativo
  PROFIT      // Utilidad
}

enum ExpenseApprovalStatus {
  PENDING_APPROVAL
  PARTIALLY_APPROVED
  APPROVED
  REJECTED
}

enum ExpenseApprovalDecision {
  APPROVED
  REJECTED
}

enum AssetStatus {
  IN_STOCK
  ASSIGNED
  PENDING_RETURN
  RETIRED
}

enum AssetMovementType {
  INTAKE
  ISSUE
  ASSIGN
  RETURN
}

enum AssetIntakeReason {
  PURCHASE
  RETURN
  INITIAL
  OTHER
}

enum AssetIssueReason {
  LOST
  DAMAGED
  DISPOSED
  OTHER
}

// ─── Módulo disciplinario ──────────────────────────────────────────────────────

/// Estado registral del apercibimiento (lo que reporta la app de escritorio).
enum DisciplinaryStatus {
  EMITIDO
  ENTREGADO
  FIRMADO
  ANULADO
}

/// Vigencia recalculada por el servidor para asegurar consistencia entre clientes.
enum DisciplinaryVigencia {
  VIGENTE
  VENCIDO
  PRESCRITO
  FINALIZADO
  ANULADO
}

/// Acción registrada en un ciclo cerrado de tratamiento.
enum DisciplinaryCycleAccion {
  COBRADO
  DADO_DE_BAJA
  OTRO
}

// ─── Catálogo de empresas (código estable en mayúsculas, ej. ALFA) ─────────────

model Company {
  code      String   @id
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  contracts        Contract[]
  deferredExpenses DeferredExpense[]
  adminExpenses    AdminExpense[]
  expenses         Expense[]

  @@map("companies")
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CONSULTA)
  company       String?
  companyEntity Company?  @relation(fields: [company], references: [code])
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]
  expenses  Expense[] @relation("ExpenseCreatedBy")

  expenseTypeApprovalSteps ExpenseTypeApprovalStep[] @relation("ExpenseTypeApprovalApprover")
  expenseApprovals         ExpenseApproval[]           @relation("ExpenseApprovalApprover")
  expenseAttachments       ExpenseAttachment[]         @relation("ExpenseAttachmentUploader")
  disciplinaryBatches      DisciplinaryImportBatch[]   @relation("DisciplinaryBatchUploader")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Contracts ────────────────────────────────────────────────────────────────

model Contract {
  id                String         @id @default(cuid())
  licitacionNo      String         @unique
  company           String
  companyEntity     Company        @relation(fields: [company], references: [code])
  client            String
  clientType        ClientType     @default(PUBLIC)
  officersCount     Int            @default(0)
  positionsCount    Int            @default(0)
  startDate         DateTime
  endDate           DateTime
  monthlyBilling    Decimal        @db.Decimal(15, 2)
  suppliesBudgetPct Decimal        @db.Decimal(6, 4)
  equivalencePct    Decimal        @default(0) @db.Decimal(10, 8)
  // Budget distribution (% of monthlyBilling, should sum to ~1.0)
  laborPct          Decimal        @default(0) @db.Decimal(6, 4)
  suppliesPct       Decimal        @default(0) @db.Decimal(6, 4)
  adminPct          Decimal        @default(0) @db.Decimal(6, 4)
  profitPct         Decimal        @default(0) @db.Decimal(6, 4)
  status            ContractStatus @default(ACTIVE)
  notes             String?        @db.Text
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  createdById       String?
  updatedById       String?

  periods               ContractPeriod[]
  billingHistory        BillingHistory[]
  uniformExpenses       UniformExpense[]
  auditFindings         AuditFinding[]
  deferredDistributions DeferredDistribution[]
  adminDistributions    AdminDistribution[]
  auditLogs             AuditLog[]
  expenses              Expense[]
  expenseDistributions  ExpenseDistribution[] @relation("ExpenseDistributions")
  locations             ContractLocation[]

  @@index([company])
  @@index([status])
  @@index([deletedAt])
  @@index([endDate])
  @@map("contracts")
}

model BillingHistory {
  id             String   @id @default(cuid())
  contractId     String
  periodMonth    DateTime
  monthlyBilling Decimal  @db.Decimal(15, 2)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, periodMonth])
  @@index([contractId])
  @@index([periodMonth])
  @@map("billing_history")
}

model ContractPeriod {
  id             String   @id @default(cuid())
  contractId     String
  periodNumber   Int
  startDate      DateTime
  endDate        DateTime
  monthlyBilling Decimal  @db.Decimal(15, 2)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, periodNumber])
  @@index([contractId])
  @@map("contract_periods")
}

// ─── Uniform Expenses ─────────────────────────────────────────────────────────

model UniformExpense {
  id          String   @id @default(cuid())
  contractId  String
  periodMonth DateTime

  shirtQty   Int     @default(0)
  shirtCost  Decimal @default(0) @db.Decimal(12, 2)
  pantsQty   Int     @default(0)
  pantsCost  Decimal @default(0) @db.Decimal(12, 2)
  shoesQty   Int     @default(0)
  shoesCost  Decimal @default(0) @db.Decimal(12, 2)
  capQty     Int     @default(0)
  capCost    Decimal @default(0) @db.Decimal(12, 2)
  vestQty    Int     @default(0)
  vestCost   Decimal @default(0) @db.Decimal(12, 2)
  beltQty    Int     @default(0)
  beltCost   Decimal @default(0) @db.Decimal(12, 2)
  bootsQty   Int     @default(0)
  bootsCost  Decimal @default(0) @db.Decimal(12, 2)
  otherQty   Int     @default(0)
  otherCost  Decimal @default(0) @db.Decimal(12, 2)
  otherDesc  String?

  totalCost   Decimal  @default(0) @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, periodMonth])
  @@index([contractId])
  @@index([periodMonth])
  @@map("uniform_expenses")
}

// ─── Audit Findings ───────────────────────────────────────────────────────────

model AuditFinding {
  id          String   @id @default(cuid())
  contractId  String
  postName    String
  findingDate DateTime @default(now())

  radioQty       Int     @default(0)
  radioCost      Decimal @default(0) @db.Decimal(12, 2)
  handcuffsQty   Int     @default(0)
  handcuffsCost  Decimal @default(0) @db.Decimal(12, 2)
  umbrellaQty    Int     @default(0)
  umbrellaCost   Decimal @default(0) @db.Decimal(12, 2)
  blackjackQty   Int     @default(0)
  blackjackCost  Decimal @default(0) @db.Decimal(12, 2)
  flashlightQty  Int     @default(0)
  flashlightCost Decimal @default(0) @db.Decimal(12, 2)
  otherQty       Int     @default(0)
  otherCost      Decimal @default(0) @db.Decimal(12, 2)
  otherDesc      String?

  totalCost   Decimal   @default(0) @db.Decimal(15, 2)
  status      String    @default("PENDING")
  resolvedAt  DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([findingDate])
  @@map("audit_findings")
}

// ─── Deferred Expenses ────────────────────────────────────────────────────────

model DeferredExpense {
  id            String          @id @default(cuid())
  company       String
  companyEntity Company         @relation(fields: [company], references: [code])
  description   String
  category      ExpenseCategory @default(OTHER)
  totalAmount   Decimal         @db.Decimal(15, 2)
  periodMonth   DateTime
  isDistributed Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdById   String?

  distributions DeferredDistribution[]

  @@index([company])
  @@map("deferred_expenses")
}

model DeferredDistribution {
  id                String   @id @default(cuid())
  deferredExpenseId String
  contractId        String
  equivalencePct    Decimal  @db.Decimal(5, 4)
  allocatedAmount   Decimal  @db.Decimal(15, 2)
  createdAt         DateTime @default(now())

  deferredExpense DeferredExpense @relation(fields: [deferredExpenseId], references: [id], onDelete: Cascade)
  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([deferredExpenseId, contractId])
  @@index([contractId])
  @@map("deferred_distributions")
}

// ─── Admin Expenses ───────────────────────────────────────────────────────────

model AdminExpense {
  id            String          @id @default(cuid())
  company       String
  companyEntity Company         @relation(fields: [company], references: [code])
  periodMonth   DateTime
  transport     Decimal         @default(0) @db.Decimal(15, 2)
  adminCosts    Decimal         @default(0) @db.Decimal(15, 2)
  phones        Decimal         @default(0) @db.Decimal(15, 2)
  phoneLines    Decimal         @default(0) @db.Decimal(15, 2)
  fuel          Decimal         @default(0) @db.Decimal(15, 2)
  otherAmount   Decimal         @default(0) @db.Decimal(15, 2)
  otherDesc     String?
  totalAmount   Decimal         @default(0) @db.Decimal(15, 2)
  isDistributed Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  createdById   String?

  distributions AdminDistribution[]

  @@unique([company, periodMonth])
  @@index([company])
  @@map("admin_expenses")
}

model AdminDistribution {
  id              String   @id @default(cuid())
  adminExpenseId  String
  contractId      String
  equivalencePct  Decimal  @db.Decimal(5, 4)
  allocatedAmount Decimal  @db.Decimal(15, 2)
  createdAt       DateTime @default(now())

  adminExpense AdminExpense @relation(fields: [adminExpenseId], references: [id], onDelete: Cascade)
  contract      Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([adminExpenseId, contractId])
  @@index([contractId])
  @@map("admin_distributions")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String    @id @default(cuid())
  userId       String
  contractId   String?
  entityType   String
  entityId     String
  action       String
  previousData String?   @db.Text
  newData      String?   @db.Text
  ipAddress    String?
  createdAt    DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])

  @@index([userId])
  @@index([contractId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Unified Expenses ─────────────────────────────────────────────────────────

/// Zona geográfica/operativa que agrupa ubicaciones (ej. Pacífico, GAM, Caribe).
model Zone {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  isActive    Boolean             @default(true)
  sortOrder   Int                 @default(0)
  /// Administrador disciplinario por zona (misma lógica que zonas_admin del escritorio).
  disciplinaryAdministrator      String?
  disciplinaryAdministratorEmail String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  locations   ContractLocation[]

  @@map("zones")
}

/// Ubicación física u operativa del contrato (contiene uno o más puestos).
model ContractLocation {
  id          String     @id @default(cuid())
  contractId  String
  contract    Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  zoneId      String?
  zone        Zone?      @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  name        String
  description String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  positions   Position[]

  @@index([contractId])
  @@index([zoneId])
  @@map("contract_locations")
}

/// Puesto de vigilancia / guardia dentro de una ubicación.
model Position {
  id          String           @id @default(cuid())
  locationId  String
  location    ContractLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name        String
  description String?
  /// Línea telefónica fija del puesto (independiente del celular físico asignado)
  phoneLine   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  expenses    Expense[]
  shifts      PositionShift[]
  assets      Asset[]           @relation("PositionAssets")
  assetMovementsFrom AssetMovement[] @relation("AssetMovementFrom")
  assetMovementsTo   AssetMovement[] @relation("AssetMovementTo")

  @@index([locationId])
  @@map("positions")
}

/// Turno asociado a un puesto (horas distintas por turno).
model PositionShift {
  id         String   @id @default(cuid())
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  label      String?
  hours      Decimal  @db.Decimal(6, 2)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([positionId])
  @@map("position_shifts")
}

model ExpenseTypeConfig {
  id          String      @id @default(cuid())
  type        ExpenseType @unique
  label       String
  color       String      @default("bg-gray-100 text-gray-700")
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  updatedAt   DateTime    @updatedAt

  @@map("expense_type_configs")
}

/// Cadena de aprobación por tipo de gasto (paso 1, luego 2, …). Usuarios concretos.
model ExpenseTypeApprovalStep {
  id             String      @id @default(cuid())
  expenseType    ExpenseType
  stepOrder      Int
  approverUserId String
  approver       User        @relation("ExpenseTypeApprovalApprover", fields: [approverUserId], references: [id], onDelete: Restrict)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([expenseType, stepOrder])
  @@index([expenseType])
  @@index([approverUserId])
  @@map("expense_type_approval_steps")
}

model ExpenseApproval {
  id             String                @id @default(cuid())
  expenseId      String
  expense        Expense               @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  stepOrder      Int
  approverUserId String
  approver       User                  @relation("ExpenseApprovalApprover", fields: [approverUserId], references: [id], onDelete: Restrict)
  decision       ExpenseApprovalDecision
  comment        String?               @db.Text
  decidedAt      DateTime              @default(now())

  @@index([expenseId])
  @@index([approverUserId])
  @@map("expense_approvals")
}

model ExpenseAttachment {
  id           String   @id @default(cuid())
  expenseId    String
  expense      Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("ExpenseAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  fileName     String
  mimeType     String
  storagePath  String
  note         String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([expenseId])
  @@index([uploadedById])
  @@map("expense_attachments")
}

model ExpenseOrigin {
  id          String    @id @default(cuid())
  name        String    @unique
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  expenses    Expense[]

  @@map("expense_origins")
}

model Expense {
  id              String        @id @default(cuid())
  /// Consecutivo autoincremental único por gasto registrado
  sequentialNo    Int           @unique @default(autoincrement())
  type            ExpenseType
  budgetLine      ExpenseBudgetLine?
  description     String
  amount          Decimal       @db.Decimal(15, 2)
  periodMonth     DateTime
  contractId      String?
  contract        Contract?     @relation(fields: [contractId], references: [id])
  positionId      String?
  position        Position?     @relation(fields: [positionId], references: [id])
  originId        String?
  origin          ExpenseOrigin? @relation(fields: [originId], references: [id])
  referenceNumber String?
  company         String?
  companyEntity   Company?      @relation(fields: [company], references: [code])
  isDeferred      Boolean       @default(false)
  isDistributed   Boolean       @default(false)
  /// Contratos que reciben el reparto del diferido. Vacío = todos los ACTIVE/PROLONGATION.
  deferredIncludeContractIds String[] @default([])
  /// Si true, el reparto usa `deferredManualAllocations` (montos fijos por contrato), no proporcional a insumos.
  deferredManualDistribution Boolean @default(false)
  /// JSON: [{ "contractId": "…", "amount": 123.45 }, …]. Suma debe coincidir con `amount` del gasto.
  deferredManualAllocations Json?
  notes           String?
  /// Registro contable / CXP (texto libre)
  registroCxp     String?       @db.Text
  /// Registro TR (texto libre)
  registroTr      String?       @db.Text
  approvalStatus        ExpenseApprovalStatus @default(APPROVED)
  /// Siguiente paso a aprobar (1-based), null si no aplica o flujo terminado
  currentApprovalStep   Int?
  requiredApprovalSteps Int                   @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String
  createdBy       User          @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  distributions   ExpenseDistribution[]
  approvals       ExpenseApproval[]
  attachments     ExpenseAttachment[]
  assetsAcquired  Asset[]           @relation("AssetAcquisitionExpense")
  assetMovements  AssetMovement[]   @relation("AssetMovementExpense")

  @@index([contractId])
  @@index([positionId])
  @@index([originId])
  @@index([company])
  @@index([approvalStatus])
  @@map("expenses")
}

model ExpenseDistribution {
  id              String   @id @default(cuid())
  expenseId       String
  expense         Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  contractId      String
  contract        Contract @relation("ExpenseDistributions", fields: [contractId], references: [id], onDelete: Cascade)
  equivalencePct  Decimal  @db.Decimal(10, 8)
  allocatedAmount Decimal  @db.Decimal(15, 2)
  createdAt       DateTime @default(now())

  @@unique([expenseId, contractId])
  @@index([contractId])
  @@map("expense_distributions")
}

// ─── Assets / Inventario ──────────────────────────────────────────────────────

/// Catálogo editable de tipos de activos (celular, arma, radio, …).
/// Cada tipo declara qué campos extra se piden a los activos de ese tipo.
model AssetType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  /// JSON: array de { key, label, type: "string"|"number"|"date"|"boolean", required }
  fields    Json     @default("[]")
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets    Asset[]

  @@map("asset_types")
}

/// Activo individual (cada unidad física identificable).
model Asset {
  id                    String       @id @default(cuid())
  typeId                String
  type                  AssetType    @relation(fields: [typeId], references: [id], onDelete: Restrict)
  /// Identificador único dentro del tipo (ej. serial, código interno).
  code                  String
  name                  String?
  brand                 String?
  model                 String?
  /// Valores para los campos declarados en AssetType.fields (ej. { imei, numero, calibre }).
  attributes            Json         @default("{}")
  status                AssetStatus  @default(IN_STOCK)
  currentPositionId     String?
  currentPosition       Position?    @relation("PositionAssets", fields: [currentPositionId], references: [id], onDelete: SetNull)
  acquisitionExpenseId  String?
  acquisitionExpense    Expense?     @relation("AssetAcquisitionExpense", fields: [acquisitionExpenseId], references: [id], onDelete: SetNull)
  acquisitionDate       DateTime?
  notes                 String?      @db.Text
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  movements             AssetMovement[]

  @@unique([typeId, code])
  @@index([status])
  @@index([currentPositionId])
  @@index([typeId])
  @@map("assets")
}

/// Historial de movimientos de un activo.
model AssetMovement {
  id              String              @id @default(cuid())
  assetId         String
  asset           Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type            AssetMovementType
  fromPositionId  String?
  fromPosition    Position?           @relation("AssetMovementFrom", fields: [fromPositionId], references: [id], onDelete: SetNull)
  toPositionId    String?
  toPosition      Position?           @relation("AssetMovementTo", fields: [toPositionId], references: [id], onDelete: SetNull)
  expenseId       String?
  expense         Expense?            @relation("AssetMovementExpense", fields: [expenseId], references: [id], onDelete: SetNull)
  intakeReason    AssetIntakeReason?
  issueReason     AssetIssueReason?
  notes           String?             @db.Text
  createdById     String?
  createdAt       DateTime            @default(now())

  @@index([assetId])
  @@index([type])
  @@index([createdAt])
  @@map("asset_movements")
}

// ─── Módulo disciplinario ──────────────────────────────────────────────────────

/// Lote de importación de Excel (auditoría: quién subió, cuántas filas).
model DisciplinaryImportBatch {
  id              String   @id @default(cuid())
  filename        String
  /// SHA-256 del contenido del archivo subido. Se usa para detectar archivos
  /// repetidos (byte a byte) y rechazarlos sin reprocesarlos. Unique.
  checksum        String?  @unique
  uploadedById    String
  uploadedBy      User     @relation("DisciplinaryBatchUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  rowsHistorial   Int      @default(0)
  rowsTratamiento Int      @default(0)
  rowsInserted    Int      @default(0)
  rowsUpdated     Int      @default(0)
  rowsSkipped     Int      @default(0)
  errorsJson      Json?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  apercibimientos DisciplinaryApercibimiento[]
  tratamientos    DisciplinaryTreatment[]

  @@index([createdAt])
  @@map("disciplinary_import_batches")
}

/// Una fila por apercibimiento emitido (importado desde el Excel de la app de escritorio).
model DisciplinaryApercibimiento {
  id                 String              @id @default(cuid())
  /// N° de apercibimiento (texto, único por sistema).
  numero             String              @unique
  fechaEmision       DateTime
  /// Código del empleado normalizado (trim + sin ceros a la izquierda si es numérico).
  codigoEmpleado     String
  /// Código tal cual vino en el Excel original (para trazabilidad).
  codigoEmpleadoRaw  String?
  nombreEmpleado     String
  zona               String?
  sucursal           String?
  cantidadOmisiones  Int                 @default(0)
  administrador      String?
  /// Correo al que se envió el apercibimiento. Sensible: no exponer en UI normal.
  correoEnviadoA     String?
  /// Ruta interna al PDF en el equipo de la app de escritorio. Sensible: no exponer.
  rutaPdf            String?
  estado             DisciplinaryStatus  @default(EMITIDO)
  /// Vigencia recalculada en el servidor según fechaEmision + estado.
  vigencia           DisciplinaryVigencia @default(VIGENTE)
  batchExterno       String?
  plantilla          String?
  planoOrigen        String?
  motivoAnulacion    String?             @db.Text
  /// Texto/ruta de la evidencia de anulación. Sensible.
  evidenciaAnulacion String?             @db.Text

  /// Contrato/Licitación tal cual vino en el Excel (para trazabilidad).
  contrato              String?
  /// Versión normalizada (uppercase, sin espacios extra) usada para emparejar con `Contract.licitacionNo`.
  contratoNormalizado   String?
  /// Cliente resuelto a partir del contrato (o editado a mano en la web).
  cliente               String?
  /// True cuando el cliente fue editado manualmente desde la web; protege re-imports incrementales.
  clienteSetManual      Boolean            @default(false)

  importBatchId      String?
  importBatch        DisciplinaryImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  /// Fechas de las omisiones de marca que generaron este apercibimiento.
  /// Una sola celda del Excel puede traer varias fechas (separadas por , ; | o saltos de línea).
  omisiones           DisciplinaryOmission[]

  @@index([codigoEmpleado, fechaEmision])
  @@index([fechaEmision])
  @@index([administrador])
  @@index([estado])
  @@index([vigencia])
  @@index([contratoNormalizado])
  @@map("disciplinary_apercibimientos")
}

/// Cada omisión de marca individual asociada a un apercibimiento. N filas por apercibimiento.
/// Importante: un mismo día puede tener varias omisiones (ej.: entrada y salida no marcadas),
/// por lo que NO se deduplica por (apercibimiento, fecha). Cada ítem reportado en la celda
/// "Fecha de Omisión" del Excel se guarda como una fila independiente preservando la cardinalidad.
/// Se usa para el reporte de omisiones por periodo, independiente de la `fechaEmision`.
model DisciplinaryOmission {
  id               String                      @id @default(cuid())
  apercibimientoId String
  apercibimiento   DisciplinaryApercibimiento  @relation(fields: [apercibimientoId], references: [id], onDelete: Cascade)
  fecha            DateTime
  /// Hora de la omisión en formato "HH:mm" o "HH:mm:ss" (texto, sin timezone).
  /// Permite distinguir varias omisiones del mismo día (ej.: entrada vs salida)
  /// sin riesgos de conversión horaria. Puede venir vacío si el Excel solo trae fecha.
  hora             String?
  /// Lugar / dispositivo / punto de marca omitido (columna del Excel de importación).
  puntoOmitido     String?                     @db.VarChar(500)
  /// Posición ordinal dentro de la celda original (para mantener orden y distinguir duplicados del mismo día).
  secuencia        Int                         @default(0)
  createdAt        DateTime                    @default(now())

  @@index([apercibimientoId, fecha])
  @@index([fecha])
  @@map("disciplinary_omisiones")
}

/// Maestro de empleados para disciplinario (CSV RRHH u otros; correo para envío de apercibimientos).
model DisciplinaryEmployeeMaster {
  id                 String   @id @default(cuid())
  codigoEmpleado     String   @unique
  codigoEmpleadoRaw  String?
  nombre             String?
  /// Número de cédula / identificación (para PDF y reportes).
  cedula             String?
  email              String?
  zona               String?
  telefono           String?
  cuentaBancaria     String?  @db.Text
  extra              Json?
  lastSourceFilename String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([updatedAt])
  @@map("disciplinary_employee_master")
}

/// Estado vigente de tratamiento por empleado (1 fila por código).
model DisciplinaryTreatment {
  id                 String   @id @default(cuid())
  codigoEmpleado     String   @unique
  codigoEmpleadoRaw  String?
  nombre             String?
  zona               String?
  fechaConvocatoria  DateTime?
  accion             String?
  cobradoDate        DateTime?

  importBatchId      String?
  importBatch        DisciplinaryImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  closedCycles       DisciplinaryClosedCycle[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([codigoEmpleado])
  @@map("disciplinary_treatments")
}

/// Ciclos cerrados (parsing del closed_cycles_json del Excel).
model DisciplinaryClosedCycle {
  id                 String                  @id @default(cuid())
  treatmentId        String
  treatment          DisciplinaryTreatment   @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  cerradoEl          DateTime?
  accion             DisciplinaryCycleAccion @default(OTRO)
  accionRaw          String?
  monto              Decimal?                @db.Decimal(14, 2)
  count              Int?
  omissions          Int?
  lastDate           DateTime?
  fechaConvocatoria  DateTime?
  nombre             String?
  zona               String?
  raw                Json

  @@index([treatmentId])
  @@index([cerradoEl])
  @@index([accion])
  @@map("disciplinary_closed_cycles")
}

/// Marca / apariencia (fila única id = default): logo en disco y colores hex para UI.
model AppBranding {
  id           String   @id @default("default")
  logoPath     String?
  primaryHex   String   @default("#2563eb")
  sidebarHex   String   @default("#0f172a")
  updatedAt    DateTime @updatedAt

  @@map("app_branding")
}

/// Ajustes disciplinarios (fila única id = default): documento y salida de correo.
model AppDisciplinarySettings {
  id                   String   @id @default("default")
  documentTitle        String   @default("APERCIBIMIENTO — OMISION DE MARCA")
  documentLegalText    String   @default("Se registra apercibimiento por omisiones de marca segun normativa interna vigente.")
  documentFooter       String   @default("Documento generado desde Syntra — Control de Rentabilidad.")
  /// Encabezado tipo formulario (similar a F-RH del escritorio).
  documentFormCode     String   @default("F-RH-30")
  documentFormRevision String   @default("05/07/2021")
  documentFormVersion  String   @default("2")
  documentFormSubtitle String   @default("Apercibimiento por omisión de marca")
  /// Párrafo tras «Estimado(a) Señor(a):». Placeholders: {{numero}}, {{fecha_emision}}, {{omisiones_count}}, {{nombre}}, {{codigo}}, {{cedula}}
  documentIntroTemplate String   @default("Por medio de la presente se le notifica el apercibimiento N° {{numero}}, registrado con fecha de emisión {{fecha_emision}}, por {{omisiones_count}} omisión(es) de marca. Los datos del funcionario y el detalle de las omisiones registradas son los siguientes:") @db.Text
  /// Imagen de firma/sello para el PDF (PNG/JPEG/WebP bajo uploads/branding).
  documentSignaturePath String?
  /// Año del último consecutivo asignado (reinicia el contador al cambiar de año civil).
  apercibimientoConsecutiveYear Int?
  /// Último número asignado en `apercibimientoConsecutiveYear` (OM-AAAA-NNNNNN).
  apercibimientoConsecutiveLast   Int      @default(0)
  /// Copia fija en todos los correos de apercibimiento (varias direcciones separadas por coma o punto y coma).
  emailFixedCc         String?  @db.Text
  emailSubjectTemplate String   @default("Apercibimiento {{numero}} — omision de marca")
  emailBodyTemplate    String   @default("Estimado/a {{nombre}}:\\n\\nSe registra el apercibimiento {{numero}} por {{omisiones_count}} omision(es) de marca. Adjuntamos la constancia en PDF.\\n\\nEste mensaje fue enviado automaticamente desde el sistema de control.")
  mailProvider         String   @default("CUSTOM_SMTP")
  smtpHost             String?
  smtpPort             Int?
  smtpSecure           Boolean?
  smtpUser             String?
  smtpPass             String?
  smtpFrom             String?
  updatedAt            DateTime @updatedAt

  @@map("app_disciplinary_settings")
}