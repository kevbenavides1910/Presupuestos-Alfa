# Ajuste host/puerto/credenciales a su PostgreSQL local (ej. :5433 si usa ese mapeo en Docker).
DATABASE_URL="postgresql://postgres:password@localhost:5432/security_contracts"
# Debe coincidir con la URL y puerto del navegador (NextAuth valida el origen). Si `next dev` usa 3002, ponga http://localhost:3002
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-change-in-production"

# Opcional: carpeta para logo de marca (por defecto ./uploads/branding). En Docker monte un volumen persistente.
# BRANDING_UPLOAD_DIR="/var/lib/app/branding"

# Opcional: envío de apercibimientos por correo (importación «marcas»). Sin SMTP_HOST no se envía ningún mail.
# SMTP_HOST="smtp.ejemplo.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Disciplinario <no-reply@ejemplo.com>"
