# ─── Copy this file to .env.production on the VPS and fill in real values ───
# Con docker-compose.prod.yml use host `postgres` (nombre del servicio), no localhost:
# DATABASE_URL="postgresql://postgres:TU_PASSWORD@postgres:5432/security_contracts?schema=public"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=security_contracts

DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/security_contracts?schema=public"

# Public URL of the app (no trailing slash). Ej. IP: http://66.94.96.57:3000 o https://dominio.com
NEXTAUTH_URL="http://66.94.96.57:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_SECRET_MIN_32_CHARS"

# Timezone — critical for date calculations (contract expiry, 6-month cutoff, etc.)
# Must match the timezone where the business operates
TZ="America/Costa_Rica"

# Optional: set Node environment
NODE_ENV="production"
